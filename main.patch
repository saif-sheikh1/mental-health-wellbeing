-    def gradcam(self, img_bytes: bytes) -> dict:
-        """
-        Gradient-based class activation map for the facial CNN.
-        Computes gradient of the predicted class score w.r.t. the input image.
-        """
-        if self.facial_model is None:
-            raise HTTPException(503, "Facial CNN not loaded")
-
-        img = Image.open(io.BytesIO(img_bytes)).convert("L").resize((IMG_SIZE, IMG_SIZE))
-        arr = np.array(img, dtype=np.float32)
-        arr = cv2.equalizeHist(arr.astype(np.uint8)).astype(np.float32) / 255.0
-        inp = tf.constant(arr.reshape(1, IMG_SIZE, IMG_SIZE, 1))
-
-        with tf.GradientTape() as tape:
-            tape.watch(inp)
-            preds = self.facial_model(inp, training=False)
-            idx   = int(tf.argmax(preds[0]))
-            score = preds[:, idx]
-
-        grads   = tape.gradient(score, inp)[0, :, :, 0].numpy()
-        heatmap = np.maximum(grads, 0)
-        heatmap /= (heatmap.max() + 1e-8)
-
-        return {
-            "emotion": EMOTION_DISPLAY[idx],
-            "heatmap": heatmap.flatten().tolist(),
-            "shape":   list(heatmap.shape),
-        }
