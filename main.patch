+        """
+        Try each path in *candidates* in order; return the first that loads.
+        Training writes both '<name>.keras' and '<name>_best.keras' checkpoints;
+        prefer the final saved model over the best-checkpoint fallback.
+        """
+        for path in candidates:
+            if not os.path.exists(path):
+                continue
+            try:
+                model = keras.models.load_model(
+                    path,
+                    custom_objects=custom_objects or {},
+                    compile=False,          # we do not need to re-compile for inference
+                )
+                print(f"  ✅  {label:30s} ← {os.path.basename(path)}")
+                return model
+            except Exception as exc:
+                print(f"  ❌  {label:30s} failed ({os.path.basename(path)}): {exc}")
+        print(f"  ⚠   {label:30s} — no valid checkpoint found")
+        return None
+
+    def _try_load_pickle(self, filename: str, label: str):
+        path = os.path.join(MODEL_DIR, filename)
+        if not os.path.exists(path):
+            print(f"  ⚠   {label:30s} — {filename} not found")
+            return None
+        try:
+            with open(path, "rb") as fh:
+                obj = pickle.load(fh)
+            print(f"  ✅  {label:30s} ← {filename}")
+            return obj
+        except Exception as exc:
+            print(f"  ❌  {label:30s} failed: {exc}")
+            return None
