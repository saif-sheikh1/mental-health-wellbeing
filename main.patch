+# ── Pydantic schemas ──────────────────────────────────────────────────────────
+
+class SensorInput(BaseModel):
+    # Ranges match training FIX-C and FIX-D
+    gsr:        float = Field(..., ge=0,   le=40952, description="Galvanic Skin Response raw ADC")
+    ppg:        float = Field(..., ge=40,  le=200,   description="Heart rate in BPM")
+    delta:      float = Field(..., ge=0.0, le=1.0,   description="EEG Delta band power (normalised)")
+    theta:      float = Field(..., ge=0.0, le=1.0,   description="EEG Theta band power (normalised)")
+    low_alpha:  float = Field(..., ge=0.0, le=1.0,   description="EEG Low Alpha band power (normalised)")
+    high_alpha: float = Field(..., ge=0.0, le=1.0,   description="EEG High Alpha band power (normalised)")
+    low_beta:   float = Field(..., ge=0.0, le=1.0,   description="EEG Low Beta band power (normalised)")
+    high_beta:  float = Field(..., ge=0.0, le=1.0,   description="EEG High Beta band power (normalised)")
+    low_gamma:  float = Field(..., ge=0.0, le=1.0,   description="EEG Low Gamma band power (normalised)")
+    mid_gamma:  float = Field(..., ge=0.0, le=1.0,   description="EEG Mid Gamma band power (normalised)")
+
+
+def _sensor_to_vals(s: SensorInput) -> list[float]:
+    """Convert SensorInput to an ordered float list matching SENSOR_COLUMNS."""
+    return [
+        s.gsr, s.ppg,
+        s.delta, s.theta,
+        s.low_alpha, s.high_alpha,
+        s.low_beta,  s.high_beta,
+        s.low_gamma, s.mid_gamma,
+    ]
