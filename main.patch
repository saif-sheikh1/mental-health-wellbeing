+    # ── Public load ───────────────────────────────────────────────────────────
+
+    def load(self) -> None:
+        print("\n" + "═" * 64)
+        print("  MindSense AI — loading models")
+        print("  MODEL_DIR:", MODEL_DIR)
+        print("═" * 64)
+
+        # 1. RNN sensor model (Step 1 of training script)
+        self.rnn_model = self._try_load_keras(
+            [
+                os.path.join(MODEL_DIR, "rnn_sensor_model.keras"),   # final save
+                os.path.join(MODEL_DIR, "rnn_sensor_best.keras"),    # best-ckpt fallback
+            ],
+            "RNN Sensor (BiLSTM+GRU+Attn)",
+        )
+        if self.rnn_model:
+            self.status["rnn_sensor"] = True
+
+        # 2. Scaler and LabelEncoder produced alongside the RNN (Step 1)
+        self.scaler = self._try_load_pickle("scaler.pkl", "RobustScaler")
+        if self.scaler:
+            self.status["scaler"] = True
+
+        self.le = self._try_load_pickle("label_encoder.pkl", "LabelEncoder")
+        if self.le:
+            self.status["label_encoder"] = True
+            # Cross-check class order — silent guard against stale artefacts
+            try:
+                loaded_classes = list(self.le.classes_)
+                if loaded_classes != STATE_NAMES:
+                    print(
+                        f"  ⚠   LabelEncoder class order differs from STATE_NAMES:\n"
+                        f"      encoder : {loaded_classes}\n"
+                        f"      expected: {STATE_NAMES}\n"
+                        f"      Using encoder order for predictions."
+                    )
+            except Exception:
+                pass
+
+        # 3. Facial CNN model (Step 2 of training script — Residual CNN, no custom objects)
+        #    Training saves to 'facial_cnn_model.keras' / 'facial_cnn_best.keras'.
+        #    Old ViT paths included as last-resort fallbacks in case you switch models.
+        self.facial_model = self._try_load_keras(
+            [
+                os.path.join(MODEL_DIR, "facial_cnn_model.keras"),   # ResNet CNN — primary
+                os.path.join(MODEL_DIR, "facial_cnn_best.keras"),    # best-ckpt fallback
+                os.path.join(MODEL_DIR, "vit_facial_model.keras"),   # legacy ViT fallback
+                os.path.join(MODEL_DIR, "vit_best.keras"),           # legacy ViT best-ckpt
+            ],
+            "Facial CNN (ResNet)",
+            custom_objects=CUSTOM_OBJECTS,
+        )
+        if self.facial_model:
+            self.status["facial_cnn"] = True
+
+        # 4. Future predictor (Step 3 of training script)
+        self.predictor = self._try_load_keras(
+            [
+                os.path.join(MODEL_DIR, "future_predictor_model.keras"),
+                os.path.join(MODEL_DIR, "predictor_best.keras"),
+            ],
+            "Future Predictor (Seq2Seq)",
+        )
+        if self.predictor:
+            self.status["predictor"] = True
+
+        # 5. SHAP background array (optional — generated only by Doc 1 training)
+        #    The unified training script (Doc 2) does NOT generate shap_background.npy,
+        #    so we fall back to a zero array and note this in the log.
+        bg_path = os.path.join(MODEL_DIR, "shap_background.npy")
+        if os.path.exists(bg_path):
+            try:
+                self.shap_background = np.load(bg_path).astype(np.float32)
+                self.status["shap_bg"] = True
+                print(f"  ✅  {'SHAP background':30s} ← shap_background.npy  {self.shap_background.shape}")
+            except Exception as exc:
+                print(f"  ❌  SHAP background load failed: {exc}")
+        else:
+            print(
+                "  ℹ   shap_background.npy absent (expected — unified training script\n"
+                "      does not generate it).  Using zero background for SHAP."
+            )
+            self.shap_background = np.zeros((1, SEQ_LEN, N_FEATURES), dtype=np.float32)
+
+        # 6. Optional state_info cross-check
+        si = self._try_load_pickle("state_info.pkl", "state_info (optional check)")
+        if si and "state_names" in si:
+            if si["state_names"] != STATE_NAMES:
+                print(
+                    f"  ⚠   state_info.pkl names differ from STATE_NAMES constant.\n"
+                    f"      state_info: {si['state_names']}\n"
+                    f"      Using STATE_NAMES constant."
+                )
+
+        print("═" * 64)
+        print(f"  Status: { {k: ('✅' if v else '❌') for k, v in self.status.items()} }")
+        print("═" * 64 + "\n")
